{
  "name": "wp-gpse",
  "version": "1.2.3",
  "description": "=== GPSE Search === Contributors: ACLabs Tags: search, google, gcse, programmable search, cse Requires at least: 6.4 Tested up to: 6.9 Stable tag: 1.2.3 Requires PHP: 8.2 License: AGPL v3 or later License URI: https://www.gnu.org/licenses/agpl-3.0.html",
  "main": "index.js",
  "scripts": {
    "start": "wp-scripts start --webpack-src-dir=gpse/src --output-path=gpse/build",
    "build": "wp-scripts build --webpack-src-dir=gpse/src --output-path=gpse/build",
    "test:unit": "wp-scripts test-unit-js --testPathPattern=gpse/src",
    "test:php": "wp-env run tests-cli phpunit",
    "lint:js": "wp-scripts lint-js gpse/src",
    "lint:css": "wp-scripts lint-style",
    "env:start": "wp-env start",
    "env:stop": "wp-env stop",
    "env:clean": "wp-env clean"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/acockrell/wp-gpse.git"
  },
  "keywords": [],
  "author": "ACLabs",
  "license": "ISC",
  "bugs": {
    "url": "https://github.com/acockrell/wp-gpse/issues"
  },
  "homepage": "https://github.com/acockrell/wp-gpse#readme",
  "devDependencies": {
    "@wordpress/env": "^11.2.0",
    "@wordpress/scripts": "^31.4.0"
  },
  "engines": {
    "node": ">=18.12.0",
    "npm": ">=8.19.2"
  }
}
